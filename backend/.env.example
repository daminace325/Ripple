# Backend environment configuration.
# Copy this file to ".env" and fill in your own values. Never commit the real .env.

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/ripple

# Used by docker-compose to initialize the Postgres container
POSTGRES_USER=USER
POSTGRES_PASSWORD=PASSWORD
POSTGRES_DB=ripple

# Auth: secret used to sign JWT access tokens (use a long random string, e.g. `python -c "import secrets;print(secrets.token_hex(32))"`)
JWT_SECRET_KEY=change-me-to-a-long-random-string
